generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  PATIENT
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String          @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  
  // Custom fields
  phoneNumber   String?         @unique // Made optional for initial Google Auth
  role          Role            @default(PATIENT)
  
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  
  appointments  Appointment[]
  enrollments   Enrollment[]
  
  priceLogs     PriceLog[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
 
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
 
  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime
 
  @@id([identifier, token])
}

model Appointment {
  id          String            @id @default(cuid())
  datetime    DateTime
  status      AppointmentStatus @default(PENDING)
  depositPaid Boolean           @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  
  patientId   String
  patient     User     @relation(fields: [patientId], references: [id])

  @@index([patientId, status])
  @@index([datetime, status])
}

model BlockoutDate {
  id        String   @id @default(cuid())
  date      DateTime @unique
  reason    String?
  createdAt DateTime @default(now())
}

model Course {
  id          String   @id @default(cuid())
  title       String
  description String?
  price       Decimal
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  enrollments Enrollment[]
}



model Enrollment {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  enrolledAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
}

// --- CMS & Configuration Models ---

model GlobalSettings {
  id                String   @id @default("settings")
  currentPrice      Decimal  @default(40000)
  sessionDuration   Int      @default(30)
  depositPercentage Int      @default(50)
  updatedAt         DateTime @updatedAt
}

model PriceLog {
  id        String   @id @default(cuid())
  price     Decimal
  adminId   String
  admin     User     @relation(fields: [adminId], references: [id])
  createdAt DateTime @default(now())
}

model WorkSchedule {
  id        String  @id @default(cuid())
  dayOfWeek Int     @unique // 0=Sun, 1=Mon, ... 6=Sat
  startTime String  // Format "HH:mm" (24h)
  endTime   String  // Format "HH:mm" (24h)
  isActive  Boolean @default(true)
}

model AvailabilityOverride {
  id        String   @id @default(cuid())
  date      DateTime @unique
  startTime String   // Format "HH:mm"
  endTime   String   // Format "HH:mm"
  createdAt DateTime @default(now())
}

model SuccessStory {
  id        String   @id @default(cuid())
  name      String
  role      String
  description String?
  imageUrl  String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
